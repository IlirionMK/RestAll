<Window x:Class="RestAll.Desktop.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppName}" 
        Height="600" 
        Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource AppName}" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding UserInfo}" 
                           FontSize="14" 
                           Foreground="White"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource WelcomeMessage}" 
                           FontSize="24" 
                           HorizontalAlignment="Center" 
                           Foreground="#7F8C8D"
                           Margin="0,0,0,20"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="{DynamicResource OpenMenuButton}" 
                            Height="35" 
                            Width="150"
                            Margin="0,0,10,0"
                            Click="OpenMenu_Click"/>
                    <Button Content="{DynamicResource OpenTablesButton}" 
                            Height="35" 
                            Width="150"
                            Margin="0,0,10,0"
                            Click="OpenTables_Click"/>
                    <Button Content="{DynamicResource OpenOrdersButton}" 
                            Height="35" 
                            Width="150"
                            Margin="0,0,10,0"
                            Click="OpenOrders_Click"/>
                    <Button Content="{DynamicResource OpenKitchenButton}" 
                            Height="35" 
                            Width="150"
                            Click="OpenKitchen_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
