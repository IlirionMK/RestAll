<Window x:Class="RestAll.Desktop.App.Views.OrdersView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RestAll - Orders" 
        Height="600" 
        Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource OrdersTitle}" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <Button Grid.Row="1" 
                Content="{DynamicResource LoadOrdersButton}" 
                Height="35" 
                Width="150" 
                HorizontalAlignment="Left"
                Command="{Binding LoadOrdersCommand}"
                Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" 
                   Text="{Binding StatusMessage}" 
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding Orders}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" 
                                BorderThickness="1" 
                                Padding="15" 
                                Margin="0,0,0,15">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding Id, StringFormat=Order ID: {0}}" 
                                               FontSize="18" 
                                               FontWeight="Bold"
                                               Margin="0,0,20,0"/>

                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding Status, StringFormat=Status: {0}}" 
                                               FontSize="16"
                                               VerticalAlignment="Center"/>

                                    <Button Grid.Column="2" 
                                            Content="{DynamicResource PayButton}" 
                                            Height="30" 
                                            Width="80"
                                            Margin="10,0,0,0"
                                            Command="{Binding DataContext.PayOrderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}"/>
                                </Grid>

                                <TextBlock Text="{Binding TotalAmount, StringFormat=Total: {0:C}}" 
                                           FontSize="20" 
                                           FontWeight="Bold"
                                           Margin="0,10,0,10"/>

                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="LightGray" 
                                                    Padding="10" 
                                                    Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Name}" 
                                                                   FontSize="16" 
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Quantity, StringFormat=Qty: {0}}" 
                                                                   FontSize="14"
                                                                   Margin="0,5,0,0"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding Price, StringFormat=C}" 
                                                               FontSize="18" 
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
