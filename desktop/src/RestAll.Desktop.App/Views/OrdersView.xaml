<Window x:Class="RestAll.Desktop.App.Views.OrdersView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:RestAll.Desktop.App.Converters"
        Title="RestAll - Orders" 
        Height="700" 
        Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:OfflineOrderConverter x:Key="OfflineOrderConverter"/>
    </Window.Resources>
    <ScrollViewer Margin="20">
        <StackPanel>
            <TextBlock Text="{DynamicResource OrdersTitle}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"/>

            <!-- Load Orders -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Button Content="{DynamicResource LoadOrdersButton}" 
                        Height="35" 
                        Width="150" 
                        Command="{Binding LoadOrdersCommand}"/>
                <Button Content="🔄 Sync Now" 
                        Height="35" 
                        Width="120" 
                        Margin="10,0,0,0"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        Command="{Binding SyncNowCommand}"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>
                <Border Background="Orange" 
                        CornerRadius="10" 
                        Padding="8,4" 
                        Margin="20,0,0,0"
                        Visibility="{Binding PendingSyncCount, Converter={StaticResource OfflineOrderConverter}}">
                    <TextBlock Text="{Binding PendingSyncCount, StringFormat='{}{0} pending'}" 
                               Foreground="White" 
                               FontWeight="Bold"
                               FontSize="12"/>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PendingSyncCount}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </StackPanel>

            <!-- Create Order Section -->
            <Border BorderBrush="Gray" 
                    BorderThickness="1" 
                    Padding="15" 
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Create New Order" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Table ID:" 
                                   VerticalAlignment="Center"
                                   Width="80"/>
                        <TextBox Text="{Binding NewOrderTableId, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="100" 
                                 Height="30"
                                 Margin="0,0,10,0"/>
                        <Button Content="Create Order" 
                                Height="30" 
                                Width="120"
                                Command="{Binding CreateOrderCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Add Item Section -->
            <Border BorderBrush="Gray" 
                    BorderThickness="1" 
                    Padding="15" 
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Add Item to Order" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0" 
                                   Text="Order ID:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Grid.Row="0" 
                                 Text="{Binding AddItemOrderId, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="80" 
                                 Height="30"
                                 Margin="0,0,20,0"/>

                        <TextBlock Grid.Column="2" Grid.Row="0" 
                                   Text="Menu Item ID:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox Grid.Column="3" Grid.Row="0" 
                                 Text="{Binding AddItemMenuItemId, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="80" 
                                 Height="30"
                                 Margin="0,0,20,0"/>

                        <TextBlock Grid.Column="4" Grid.Row="0" 
                                   Text="Quantity:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox Grid.Column="5" Grid.Row="0" 
                                 Text="{Binding AddItemQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="60" 
                                 Height="30"/>

                        <TextBlock Grid.Column="0" Grid.Row="1" 
                                   Text="Comment:" 
                                   VerticalAlignment="Center"
                                   Margin="0,10,10,0"/>
                        <TextBox Grid.Column="1" Grid.ColumnSpan="3" Grid.Row="1" 
                                 Text="{Binding AddItemComment, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="280" 
                                 Height="30"
                                 Margin="0,10,20,0"/>

                        <Button Grid.Column="4" Grid.ColumnSpan="2" Grid.Row="1" 
                                Content="Add Item" 
                                Height="30" 
                                Width="150"
                                Command="{Binding AddItemCommand}"
                                Margin="0,10,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Remove Item Section -->
            <Border BorderBrush="Gray" 
                    BorderThickness="1" 
                    Padding="15" 
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Remove Item from Order" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Order ID:" 
                                   VerticalAlignment="Center"
                                   Width="80"/>
                        <TextBox Text="{Binding RemoveItemOrderId, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="80" 
                                 Height="30"
                                 Margin="0,0,20,0"/>
                        <TextBlock Text="Order Item ID:" 
                                   VerticalAlignment="Center"
                                   Width="110"/>
                        <TextBox Text="{Binding RemoveItemOrderItemId, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="80" 
                                 Height="30"
                                 Margin="0,0,20,0"/>
                        <Button Content="Remove Item" 
                                Height="30" 
                                Width="120"
                                Command="{Binding RemoveItemCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Orders List -->
            <ItemsControl ItemsSource="{Binding Orders}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" 
                                BorderThickness="1" 
                                Padding="15" 
                                Margin="0,0,0,15">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Id}" Value="-1">
                                            <Setter Property="Background" Value="#FFF3E0"/>
                                            <Setter Property="BorderBrush" Value="#FF9800"/>
                                        </DataTrigger>
                                        <!-- For any negative ID (offline order) -->
                                        <DataTrigger Binding="{Binding Id, Converter={StaticResource OfflineOrderConverter}}" Value="True">
                                            <Setter Property="Background" Value="#FFF3E0"/>
                                            <Setter Property="BorderBrush" Value="#FF9800"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Id, StringFormat=Order ID: {0}}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold"
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Text="⏳ PENDING SYNC" 
                                                   FontSize="12"
                                                   Foreground="Orange"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding Converter={StaticResource OfflineOrderConverter}}">
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status, StringFormat=Status: {0}}" 
                                                   FontSize="16"/>
                                        <TextBlock x:Name="BillRequestedIndicator"
                                                   Text=" 🧾 Bill Requested" 
                                                   FontSize="14"
                                                   Foreground="Orange"
                                                   FontWeight="SemiBold"
                                                   Margin="15,0,0,0"
                                                   Visibility="Collapsed">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="BillingRequested">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <Button Grid.Column="2" 
                                            Content="Request Bill" 
                                            Height="30" 
                                            Width="100"
                                            Margin="10,0,5,0"
                                            Command="{Binding DataContext.RequestBillCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}"/>

                                    <Button Grid.Column="3" 
                                            Content="{DynamicResource PayButton}" 
                                            Height="30" 
                                            Width="80"
                                            Margin="5,0,0,0"
                                            Command="{Binding DataContext.PayOrderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}"/>
                                </Grid>

                                <TextBlock Text="{Binding TotalAmount, StringFormat=Total: {0:C}}" 
                                           FontSize="20" 
                                           FontWeight="Bold"
                                           Margin="0,10,0,10"/>

                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="LightGray" 
                                                    Padding="10" 
                                                    Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Name}" 
                                                                   FontSize="16" 
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Quantity, StringFormat=Qty: {0}}" 
                                                                   FontSize="14"
                                                                   Margin="0,5,0,0"/>
                                                        <TextBlock Text="{Binding Comment}" 
                                                                   FontSize="12"
                                                                   Foreground="Gray"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding Price, StringFormat=C}" 
                                                               FontSize="18" 
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Window>
