<Window x:Class="RestAll.Desktop.App.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RestAll - Logowanie" 
        Height="450" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="40">
        <StackPanel>
            <TextBlock Text="{DynamicResource AppName}" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,40"/>
            
            <TextBlock Text="{DynamicResource EmailLabel}" 
                       FontSize="14" 
                       Margin="0,0,0,5"/>
            <TextBox x:Name="EmailTextBox" 
                     Height="30" 
                     Margin="0,0,0,20"
                     Padding="5"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
            
            <TextBlock Text="{DynamicResource PasswordLabel}" 
                       FontSize="14" 
                       Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" 
                         Height="30" 
                         Margin="0,0,0,20"
                          Padding="5"
                          PasswordChanged="PasswordBox_PasswordChanged"/>
            
            <TextBlock x:Name="TwoFactorLabel" 
                       Text="{DynamicResource TwoFactorLabel}" 
                       FontSize="14" 
                       Margin="0,0,0,5"
                       Visibility="{Binding IsTwoFactorMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBox x:Name="TwoFactorTextBox" 
                     Height="30" 
                     Margin="0,0,0,20"
                     Padding="5"
                      Visibility="{Binding IsTwoFactorMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Text="{Binding TwoFactorCode, UpdateSourceTrigger=PropertyChanged}"/>
            
            <Button x:Name="LoginButton" 
                    Content="{DynamicResource LoginButton}" 
                    Height="35" 
                    Margin="0,0,0,10"
                    Command="{Binding LoginCommand}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTwoFactorMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button x:Name="VerifyTwoFactorButton"
                    Content="{DynamicResource VerifyTwoFactorButton}"
                    Height="35"
                    Margin="0,0,0,10"
                    Command="{Binding VerifyTwoFactorCommand}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTwoFactorMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <TextBlock x:Name="StatusTextBlock" 
                       Text="{Binding StatusMessage}" 
                       Foreground="{Binding StatusColor}" 
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
