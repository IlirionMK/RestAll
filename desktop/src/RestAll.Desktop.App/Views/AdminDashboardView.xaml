<Window x:Class="RestAll.Desktop.App.Views.AdminDashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard"
        Height="850"
        Width="1250"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <TabControl>
            <TabItem Header="Staff">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Load staff" Width="130" Height="32" Margin="0,0,10,0" Command="{Binding LoadStaffCommand}"/>
                            <TextBlock Text="{Binding StaffStatusMessage}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <GroupBox Header="Create staff member" Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Name -->
                                <TextBlock Grid.Column="0" Grid.Row="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,5,10" Width="60"/>
                                <TextBox Grid.Column="1" Grid.Row="0" Margin="0,0,10,10" Height="30" 
                                         Text="{Binding NewStaffName, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Staff member name"/>

                                <!-- Row 0: Email -->
                                <TextBlock Grid.Column="2" Grid.Row="0" Text="Email:" VerticalAlignment="Center" Margin="0,0,5,10" Width="60"/>
                                <TextBox Grid.Column="3" Grid.Row="0" Margin="0,0,10,10" Height="30" 
                                         Text="{Binding NewStaffEmail, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Staff member email"/>

                                <!-- Row 0: Password -->
                                <TextBlock Grid.Column="4" Grid.Row="0" Text="Password:" VerticalAlignment="Center" Margin="0,0,5,10" Width="60"/>
                                <PasswordBox Grid.Column="5" Grid.Row="0" Margin="0,0,10,10" Height="30"
                                             PasswordChanged="NewStaffPassword_PasswordChanged"
                                             ToolTip="Initial password"/>

                                <!-- Row 1: Role -->
                                <TextBlock Grid.Column="0" Grid.Row="1" Text="Role:" VerticalAlignment="Center" Margin="0,0,5,0" Width="60"/>
                                <ComboBox Grid.Column="1" Grid.Row="1" Margin="0,0,10,0" Height="30"
                                          ItemsSource="{Binding AvailableRoles}"
                                          SelectedItem="{Binding NewStaffRole, Mode=TwoWay}"
                                          ToolTip="Staff role"/>

                                <!-- Row 1: Create button -->
                                <Button Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="2" Content="Create" Width="120" Height="30"
                                        Command="{Binding CreateStaffCommand}"/>
                            </Grid>
                        </GroupBox>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>

                            <GroupBox Grid.Column="0" Header="Staff list" Margin="0,0,15,0">
                                <ListBox ItemsSource="{Binding StaffMembers}"
                                         SelectedItem="{Binding SelectedStaffMember, Mode=TwoWay}"
                                         Margin="10"
                                         MinHeight="400">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#D0D0D0" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15"/>
                                                    <TextBlock Text="{Binding Email}" Foreground="DimGray"/>
                                                    <TextBlock Text="{Binding Role, StringFormat=Role: {0}}" Margin="0,5,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>

                            <GroupBox Grid.Column="1" Header="Selected staff actions">
                                <StackPanel Margin="10">
                                    <TextBlock Text="{Binding SelectedStaffMember.Name, TargetNullValue=Select a staff member}" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedStaffMember.Email}" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding SelectedStaffMember.Role, StringFormat=Current role: {0}}" Margin="0,5,0,10"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <ComboBox Width="180" Height="30" ItemsSource="{Binding AvailableRoles}" SelectedItem="{Binding SelectedStaffRole, Mode=TwoWay}"/>
                                        <Button Content="Update role" Width="120" Height="30" Margin="10,0,10,0" Command="{Binding UpdateSelectedStaffRoleCommand}"/>
                                        <Button Content="Delete" Width="100" Height="30" Command="{Binding DeleteSelectedStaffCommand}"/>
                                    </StackPanel>

                                    <TextBlock Text="Tip: wybierz pracownika z listy, aby zmienić rolę lub usunąć konto." TextWrapping="Wrap" Foreground="DimGray"/>
                                </StackPanel>
                            </GroupBox>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Analytics">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Load analytics" Width="150" Height="32" Margin="0,0,10,0" Command="{Binding LoadAnalyticsCommand}"/>
                            <TextBlock Text="{Binding AnalyticsStatusMessage}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Column="0" BorderBrush="#D0D0D0" BorderThickness="1" Padding="15" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Revenue" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding AnalyticsSummary.Revenue.Today, StringFormat=Today: {0:C}}" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding AnalyticsSummary.Revenue.ThisWeek, StringFormat=This week: {0:C}}"/>
                                    <TextBlock Text="{Binding AnalyticsSummary.Revenue.ThisMonth, StringFormat=This month: {0:C}}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" BorderBrush="#D0D0D0" BorderThickness="1" Padding="15" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Orders" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding AnalyticsSummary.Orders.Today, StringFormat=Today: {0}}" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding AnalyticsSummary.Orders.ThisWeek, StringFormat=This week: {0}}"/>
                                    <TextBlock Text="{Binding AnalyticsSummary.Orders.ThisMonth, StringFormat=This month: {0}}"/>
                                    <TextBlock Text="{Binding AnalyticsSummary.Orders.AverageValue, StringFormat=Average value: {0:C}}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="0" Grid.Row="1" BorderBrush="#D0D0D0" BorderThickness="1" Padding="15" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Reservations" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding AnalyticsSummary.Reservations.Today, StringFormat=Today: {0}}" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding AnalyticsSummary.Reservations.ThisWeek, StringFormat=This week: {0}}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Grid.Row="1" BorderBrush="#D0D0D0" BorderThickness="1" Padding="15" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Top items" FontSize="18" FontWeight="Bold"/>
                                    <ItemsControl ItemsSource="{Binding AnalyticsSummary.TopItems}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                                    <TextBlock Text="{Binding QuantitySold, StringFormat=Qty: {0}}" DockPanel.Dock="Right"/>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Logs">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Load logs" Width="120" Height="32" Margin="0,0,10,0" Command="{Binding LoadLogsCommand}"/>
                            <TextBlock Text="{Binding LogsStatusMessage}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <GroupBox Header="Filters" Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBox Grid.Column="0" Grid.Row="0" Margin="0,0,10,10" Height="30"
                                         Text="{Binding AuditLogActionFilter, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Action"/>
                                <TextBox Grid.Column="1" Grid.Row="0" Margin="0,0,10,10" Height="30"
                                         Text="{Binding AuditLogUserIdFilter, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="User ID"/>
                                <DatePicker Grid.Column="2" Grid.Row="0" Margin="0,0,10,10" Height="30"
                                            SelectedDate="{Binding AuditLogDateFrom, Mode=TwoWay}"/>
                                <DatePicker Grid.Column="3" Grid.Row="0" Margin="0,0,10,10" Height="30"
                                            SelectedDate="{Binding AuditLogDateTo, Mode=TwoWay}"/>
                                <TextBox Grid.Column="0" Grid.Row="1" Margin="0,0,10,0" Height="30"
                                         Text="{Binding AuditLogPerPage, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Per page"/>
                                <TextBlock Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="3" VerticalAlignment="Center"
                                           Text="Action / user / date filters are optional. Per page defaults to 25."/>
                            </Grid>
                        </GroupBox>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="{Binding AuditLogPage.CurrentPage, StringFormat=Page: {0}}" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding AuditLogPage.LastPage, StringFormat=Last page: {0}}" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding AuditLogPage.Total, StringFormat=Total logs: {0}}"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding AuditLogPage.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#D0D0D0" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Action}" FontWeight="Bold" FontSize="15"/>
                                            <TextBlock Text="{Binding UserName, StringFormat=User: {0}}"/>
                                            <TextBlock Text="{Binding ModelType, StringFormat=Model: {0}}"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat=Created: {0:yyyy-MM-dd HH:mm:ss}}"/>
                                            <TextBlock Text="{Binding IpAddress, StringFormat=IP: {0}}"/>
                                            <TextBlock Text="{Binding Payload}" TextWrapping="Wrap" Foreground="DimGray" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

