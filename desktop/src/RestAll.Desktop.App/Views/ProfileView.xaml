<Window x:Class="RestAll.Desktop.App.Views.ProfileView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RestAll - Profile" 
        Height="500" 
        Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="My Profile" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"/>

            <!-- Load Profile -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Button Content="Load Profile" 
                        Height="35" 
                        Width="150" 
                        Command="{Binding LoadProfileCommand}"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>
            </StackPanel>

            <!-- Profile Details -->
            <Border BorderBrush="Gray" 
                    BorderThickness="1" 
                    Padding="20" 
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Profile Information" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0" 
                                   Text="ID:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,10"/>
                        <TextBox Grid.Column="1" Grid.Row="0" 
                                   Text="{Binding CurrentProfile.Id}" 
                                   Height="30"
                                   Margin="0,0,0,10"/>

                        <TextBlock Grid.Column="0" Grid.Row="1" 
                                   Text="Name:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,10"/>
                        <TextBox Grid.Column="1" Grid.Row="1" 
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="30"
                                 Margin="0,0,0,10"/>

                        <TextBlock Grid.Column="0" Grid.Row="2" 
                                   Text="Email:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,10"/>
                        <TextBox Grid.Column="1" Grid.Row="2" 
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="30"
                                 Margin="0,0,0,10"/>

                        <TextBlock Grid.Column="0" Grid.Row="3" 
                                   Text="Role:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,10"/>
                        <TextBox Grid.Column="1" Grid.Row="3" 
                                 Text="{Binding Role, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="30"
                                 Margin="0,0,0,10"/>
                    </Grid>

                    <Button Content="Update Profile" 
                            Height="35" 
                            Width="150"
                            Command="{Binding UpdateProfileCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
