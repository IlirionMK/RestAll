<Window x:Class="RestAll.Desktop.App.Views.ForgotPasswordView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RestAll - Forgot Password" 
        Height="400" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="40">
        <StackPanel>
            <TextBlock Text="Reset Password" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>
            
            <TextBlock Text="Enter your email address and we'll send you a link to reset your password." 
                       FontSize="12" 
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"
                       Foreground="Gray"/>
            
            <TextBlock Text="Email" 
                       FontSize="14" 
                       Margin="0,0,0,5"/>
            <TextBox x:Name="EmailTextBox" 
                     Height="35" 
                     Margin="0,0,0,20"
                     Padding="8"
                     FontSize="14"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
            
            <Button x:Name="SendResetLinkButton" 
                    Content="Send Reset Link" 
                    Height="40" 
                    Margin="0,0,0,15"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Command="{Binding SendResetLinkCommand}"
                    Background="#4CAF50"
                    Foreground="White">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45A049"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <Button x:Name="BackToLoginButton" 
                    Content="← Back to Login" 
                    Height="35" 
                    Margin="0,0,0,10"
                    FontSize="13"
                    Command="{Binding BackToLoginCommand}"
                    Background="Transparent"
                    BorderThickness="1"
                    BorderBrush="Gray">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <TextBlock x:Name="StatusTextBlock" 
                       Text="{Binding StatusMessage}" 
                       Foreground="{Binding StatusColor}" 
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>
