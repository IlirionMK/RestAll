<Window x:Class="RestAll.Desktop.App.Views.ReservationsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RestAll - Reservations" 
        Height="700" 
        Width="1000"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer Margin="20">
        <StackPanel>
            <TextBlock Text="Reservations" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"/>

            <!-- Load Reservations -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <DatePicker SelectedDate="{Binding SelectedDate}" 
                            Height="35" 
                            Width="150"
                            Margin="0,0,10,0"/>
                <Button Content="Load Reservations" 
                        Height="35" 
                        Width="150" 
                        Command="{Binding LoadReservationsCommand}"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>
            </StackPanel>

            <!-- Create Reservation Section -->
            <Border BorderBrush="Gray" 
                    BorderThickness="1" 
                    Padding="15" 
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Create New Reservation" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0" 
                                   Text="Customer Name:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Grid.Row="0" 
                                 Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="200" 
                                 Height="30"
                                 Margin="0,0,20,0"/>

                        <TextBlock Grid.Column="2" Grid.Row="0" 
                                   Text="Phone:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox Grid.Column="3" Grid.Row="0" 
                                 Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="150" 
                                 Height="30"
                                 Margin="0,0,20,0"/>

                        <TextBlock Grid.Column="4" Grid.Row="0" 
                                   Text="Email:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox Grid.Column="5" Grid.Row="0" 
                                 Text="{Binding CustomerEmail, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="200" 
                                 Height="30"/>

                        <TextBlock Grid.Column="0" Grid.Row="1" 
                                   Text="Reservation Date:" 
                                   VerticalAlignment="Center"
                                   Margin="0,10,10,0"/>
                        <DatePicker Grid.Column="1" Grid.Row="1" 
                                    SelectedDate="{Binding ReservationDate}" 
                                    Height="30"
                                    Margin="0,10,20,0"/>

                        <TextBlock Grid.Column="2" Grid.Row="1" 
                                   Text="Time:" 
                                   VerticalAlignment="Center"
                                   Margin="0,10,10,0"/>
                        <TextBox Grid.Column="3" Grid.Row="1" 
                                 Text="{Binding ReservationTime, StringFormat=HH:mm, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="150" 
                                 Height="30"
                                 Margin="0,10,20,0"/>

                        <TextBlock Grid.Column="4" Grid.Row="1" 
                                   Text="Table ID:" 
                                   VerticalAlignment="Center"
                                   Margin="0,10,10,0"/>
                        <TextBox Grid.Column="5" Grid.Row="1" 
                                 Text="{Binding TableId, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="80" 
                                 Height="30"
                                 Margin="0,10,0,0"/>

                        <TextBlock Grid.Column="0" Grid.Row="2" 
                                   Text="Number of Guests:" 
                                   VerticalAlignment="Center"
                                   Margin="0,10,10,0"/>
                        <TextBox Grid.Column="1" Grid.Row="2" 
                                 Text="{Binding NumberOfGuests, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="80" 
                                 Height="30"
                                 Margin="0,10,20,0"/>

                        <TextBlock Grid.Column="2" Grid.Row="2" 
                                   Text="Special Requests:" 
                                   VerticalAlignment="Center"
                                   Margin="0,10,10,0"/>
                        <TextBox Grid.Column="3" Grid.ColumnSpan="3" Grid.Row="2" 
                                 Text="{Binding SpecialRequests, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="400" 
                                 Height="30"
                                 Margin="0,10,0,0"/>

                        <Button Grid.Column="0" Grid.ColumnSpan="6" Grid.Row="3" 
                                Content="Create Reservation" 
                                Height="35" 
                                Width="200"
                                Command="{Binding CreateReservationCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Cancel Reservation Section -->
            <Border BorderBrush="Gray" 
                    BorderThickness="1" 
                    Padding="15" 
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Cancel Reservation" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Reservation ID:" 
                                   VerticalAlignment="Center"
                                   Width="110"/>
                        <TextBox Text="{Binding CancelReservationId, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="80" 
                                 Height="30"
                                 Margin="0,0,20,0"/>
                        <Button Content="Cancel Reservation" 
                                Height="30" 
                                Width="150"
                                Command="{Binding CancelReservationCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Reservations List -->
            <ItemsControl ItemsSource="{Binding Reservations}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" 
                                BorderThickness="1" 
                                Padding="15" 
                                Margin="0,0,0,15">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding Id, StringFormat=Reservation ID: {0}}" 
                                               FontSize="18" 
                                               FontWeight="Bold"
                                               Margin="0,0,20,0"/>

                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding Status, StringFormat=Status: {0}}" 
                                               FontSize="16"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding TableId, StringFormat=Table: {0}}" 
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               Margin="20,0,0,0"/>
                                </Grid>

                                <TextBlock Text="{Binding CustomerName, StringFormat=Customer: {0}}" 
                                           FontSize="16" 
                                           FontWeight="SemiBold"
                                           Margin="0,10,0,5"/>

                                <TextBlock Text="{Binding CustomerPhone, StringFormat=Phone: {0}}" 
                                           FontSize="14"
                                           Margin="0,0,0,2"/>

                                <TextBlock Text="{Binding CustomerEmail, StringFormat=Email: {0}}" 
                                           FontSize="14"
                                           Margin="0,0,0,2"/>

                                <TextBlock Text="{Binding ReservationDate, StringFormat=Date: {0:yyyy-MM-dd}}" 
                                           FontSize="14"
                                           Margin="0,0,0,2"/>

                                <TextBlock Text="{Binding ReservationTime, StringFormat=Time: {0:HH:mm}}" 
                                           FontSize="14"
                                           Margin="0,0,0,2"/>

                                <TextBlock Text="{Binding NumberOfGuests, StringFormat=Guests: {0}}" 
                                           FontSize="14"
                                           Margin="0,0,0,5"/>

                                <TextBlock Text="{Binding SpecialRequests}" 
                                           FontSize="12"
                                           Foreground="Gray"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Window>
