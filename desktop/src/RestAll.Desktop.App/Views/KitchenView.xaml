<Window x:Class="RestAll.Desktop.App.Views.KitchenView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RestAll - Kitchen" 
        Height="600" 
        Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource KitchenTitle}" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <Button Grid.Row="1" 
                Content="{DynamicResource LoadTicketsButton}" 
                Height="35" 
                Width="150" 
                HorizontalAlignment="Left"
                Command="{Binding LoadTicketsCommand}"
                Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" 
                   Text="{Binding StatusMessage}" 
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding Tickets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" 
                                BorderThickness="1" 
                                Padding="15" 
                                Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="{Binding Id, StringFormat=Ticket ID: {0}}" 
                                           FontSize="18" 
                                           FontWeight="Bold"
                                           Margin="0,0,20,0"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding MenuItemName}" 
                                               FontSize="20" 
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Quantity, StringFormat=Qty: {0}}" 
                                               FontSize="16"
                                               Margin="0,5,0,5"/>
                                    <TextBlock Text="{Binding Price, StringFormat=Price: {0:C}}" 
                                                FontSize="16"
                                                Margin="0,5,0,5"/>
                                    <TextBlock Text="{Binding TableName, StringFormat=Table: {0}}" 
                                               FontSize="14"
                                               Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding Comment}" 
                                               FontSize="14"
                                               FontStyle="Italic"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Status, StringFormat=Status: {0}}" 
                                               FontSize="16"
                                               Margin="0,0,0,10"/>
                                    <Button Content="{DynamicResource PreparingButton}" 
                                            Height="30" 
                                            Width="100"
                                            Margin="0,5,0,0"
                                            Command="{Binding DataContext.UpdateTicketStatusCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}"/>
                                    <Button Content="{DynamicResource ReadyButton}" 
                                            Height="30" 
                                            Width="100"
                                            Margin="0,5,0,0"
                                            Command="{Binding DataContext.SetReadyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
